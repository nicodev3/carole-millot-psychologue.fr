---
import { navigation, site } from "../config/site";
---

<footer class="g-footer">
  <div class="container flex-l">
    <div class="w-33-l">
      <h2>Plan du site</h2>
      <nav class="g-footer__nav">
        <ul>
          <li><a href="/">Accueil</a></li>
          {navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        </ul>
      </nav>
    </div>
    <div class="w-33-l">
      <h2>{site.name} {site.profession}</h2>
      <h3>Diplômée de l'Université Paris V</h3>
      <address class="g-footer__address">
        <p>{site.addressLine1}</p>
        <p>{site.addressLine2}</p>
        <p>
          Consultation sur rdv |
          {" "}
          <a href={site.phoneHref}>{site.phoneDisplay}</a>
        </p>
      </address>
    </div>
    <div class="w-33-l">
      <h2>Informations légales</h2>
      <p>N° ADELI : {site.adeli}</p>
      <p>N° Siret : {site.siret}</p>
    </div>
  </div>
</footer>
