---
import { navigation, site } from "../config/site";
---

<footer class="g-footer">
  <div class="mx-auto flex max-w-[1200px] flex-col gap-8 px-2 md:flex-row">
    <div class="space-y-4 md:w-1/3 md:px-4">
      <h2 class="mb-4">Plan du site</h2>
      <nav class="g-footer__nav">
        <ul class="space-y-4">
          <li><a href="/">Accueil</a></li>
          {navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        </ul>
      </nav>
    </div>
    <div class="space-y-4 md:w-1/3 md:px-4">
      <h2 class="mb-4">{site.name} {site.profession}</h2>
      <h3>Diplômée de l'Université Paris V</h3>
      <address class="g-footer__address space-y-2">
        <p>{site.addressLine1}</p>
        <p>{site.addressLine2}</p>
        <p>
          Consultation sur rdv |
          {" "}
          <a href={site.phoneHref}>{site.phoneDisplay}</a>
        </p>
      </address>
    </div>
    <div class="space-y-4 md:w-1/3 md:px-4">
      <h2 class="mb-4">Informations légales</h2>
      <p>N° ADELI : {site.adeli}</p>
      <p>N° Siret : {site.siret}</p>
    </div>
  </div>
</footer>
