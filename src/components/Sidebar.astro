---
import { site } from "../config/site";
---

<aside class="w-full bg-[var(--primary-lightest)] md:ml-[5%] md:w-[25%] md:p-8">
  <div class="mb-4 rounded bg-white p-4 shadow-[var(--base-box-shadow)]">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" viewBox="0 0 15 15" aria-hidden="true">
      <path d="M11 9c-1 1-1 2-2 2s-2-1-3-2-2-2-2-3 1-1 2-2-2-4-3-4-3 3-3 3c0 2 2.06 6.06 4 8s6 4 8 4c0 0 3-2 3-3s-3-4-4-3z"></path>
    </svg>
    <p>Consultations sur rendez-vous au :</p>
    <p><a href={site.phoneHref}>{site.phoneDisplay}</a></p>
  </div>
  <div class="mb-4 rounded bg-white p-4 shadow-[var(--base-box-shadow)]">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" viewBox="0 0 12 15.96" aria-hidden="true">
      <path d="M6 0C.13 0-1.31 8.15 6 14c7.32-5.86 5.87-14 0-14zm0 8.06c-4 0-4.05-6.13 0-6.13s4.05 6.13 0 6.13zm0-1.12a1.94 1.94 0 0 0 0-3.88 1.94 1.94 0 0 0 0 3.88zm4.28 4c-.22.35-.45.68-.68 1 4 1.85-3.45 4.1-7.32 2.17-1.53-.76-1.39-1.46.11-2.17-.23-.31-.46-.64-.68-1C.65 11.44 0 12.18 0 13c0 4 12 4 12 0 0-.82-.65-1.56-1.72-2.1z"></path>
    </svg>
    <address class="g-sidebar__address">
      <p>{site.addressLine1}</p>
      <p>{site.addressLine2}</p>
    </address>
  </div>
</aside>
