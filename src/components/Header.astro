---
import { navigation, site } from "../config/site";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
---

<header class="g-header">
  <div class="mx-auto h-full max-w-[1200px] px-2">
    <div class="flex h-full items-center justify-between">
      <div class="logo text-2xl transition-transform duration-200 ease-out hover:translate-x-[0.2rem]">
        <a href="/" aria-label="Accueil Carole Millot">
          {site.name} <span class="relative top-[5px] block text-[0.8rem] italic">{site.profession}</span>
        </a>
      </div>
      <button
        class="hamburger-box"
        type="button"
        aria-expanded="false"
        aria-controls="main-navigation"
        aria-label="Ouvrir la navigation"
        data-menu-button
      >
        <span class="hamburger-inner"></span>
      </button>
      <nav id="main-navigation" class="g-header__nav" data-menu>
        <ul>
          {
            navigation.map((item) => (
              <li class={pathname === item.href ? "active" : undefined}>
                <a href={item.href} class="o-nav__a" data-menu-link>{item.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  import "../scripts/header-menu.ts";
</script>
